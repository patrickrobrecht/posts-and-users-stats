{
  "private": true,
  "devDependencies": {
    "@wordpress/eslint-plugin": "^24.5.0",
    "@wordpress/stylelint-config": "^23.35.0",
    "prettier": "^3.8.2"
  },
  "scripts": {
    "cs": "npm run csCSS && npm run csJS",
    "csCSS": "npx stylelint assets/style.css",
    "csJS": "npx eslint assets/functions.js",
    "csfix": "npm run csfixCSS && npm run csfixJS",
    "csfixCSS": "npx stylelint assets/style.css --fix",
    "csfixJS": "npx eslint assets/functions.js --fix"
  },
  "eslintConfig": {
    "extends": "plugin:@wordpress/eslint-plugin/recommended",
    "rules": {
      "camelcase": "off"
    },
    "env": {
      "browser": true,
      "jquery": true
    },
    "globals": {
      "Chartist": "readonly",
      "moment":"readonly"
    }
  },
  "stylelint": {
    "extends": "@wordpress/stylelint-config",
    "rules": {
      "font-weight-notation": "named-where-possible"
    }
  }
}
