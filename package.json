{
	"private": true,
	"devDependencies": {
		"@wordpress/eslint-plugin": "^25.0.0",
		"@wordpress/stylelint-config": "^23.36.0",
		"globals": "^17.5.0",
		"prettier": "^3.8.3"
	},
	"scripts": {
		"cs": "npm run csCSS && npm run csJS",
		"csCSS": "npx stylelint assets/style.css",
		"csJS": "npx eslint assets/functions.js eslint.config.mjs",
		"csfix": "npm run csfixCSS && npm run csfixJS",
		"csfixCSS": "npx stylelint assets/style.css --fix",
		"csfixJS": "npx eslint assets/functions.js eslint.config.mjs --fix"
	},
	"stylelint": {
		"extends": "@wordpress/stylelint-config",
		"rules": {
			"font-weight-notation": "named-where-possible"
		}
	}
}
